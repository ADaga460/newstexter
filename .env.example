# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# --- App ---
# Absolute or relative path to the SQLite database file.
NEWSTEXTER_DB=data/newstexter.db
# Public base URL of this service (used only for logging / docs). The Twilio
# inbound webhook should point at https://<this-host>/sms
NEWSTEXTER_BASE_URL=https://your-host.example.com
# Set to 1 to skip Twilio request-signature validation on /sms (LOCAL DEV ONLY).
NEWSTEXTER_SKIP_TWILIO_VALIDATION=0
